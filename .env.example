# AI_COMPARE_API_KEY=sk-ant-compare-xxxx
# AI_COMPARE_MODEL=claude-3-5-sonnet-20241022
# AI_COMPARE_MODEL_LABEL=Claude 3.5 Sonnet

# Runtime paths
DATA_DIR=/app/data
PROMPT_ASSET_DB_PATH=/app/data/app.db
